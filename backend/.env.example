SERVER_PORT=8080

DB_HOST=postgres
DB_PORT=5432
DB_NAME=hearintent
DB_USER=hearintent
DB_PASSWORD=hearintent

JWT_SECRET=change-this-super-secret-key-in-production-min-256-bits-long
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=7

OTP_TTL_MIN=5
OTP_RESEND_COOLDOWN_SEC=60
OTP_MAIL_FROM=no-reply@hearintent.app
OTP_MOCK_MODE=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

AI_WORKER_HOST=ai-worker
AI_WORKER_PORT=50051

FLAT_LOG_DIR=/var/log/hearintent/backend

CORS_ALLOWED_ORIGINS=http://localhost:3000
