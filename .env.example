# Root-level overrides for docker-compose.yml.
# Copy to .env and adjust as needed; docker-compose automatically loads .env
# from the project root.

# --- Postgres ---
POSTGRES_DB=hearintent
POSTGRES_USER=hearintent
POSTGRES_PASSWORD=hearintent

# --- Backend ---
JWT_SECRET=change-this-super-secret-key-in-production-min-256-bits-long
OTP_MOCK_MODE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# --- AI Worker ---
WHISPER_MODEL_SIZE=small
INTENT_MODEL_NAME=facebook/bart-large-mnli

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080
